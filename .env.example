# Bententrade — переменные окружения для Node/Railway.
# На Railway задаются в разделе Variables (DATABASE_URL появляется автоматически
# после привязки плагина PostgreSQL). Локально скопируйте в .env.

# PostgreSQL (Railway подставляет автоматически при подключённой БД)
DATABASE_URL=postgres://user:password@host:5432/railway
# Для внешнего подключения к БД, требующего TLS — раскомментируйте:
# DATABASE_SSL=true

# Порт (Railway задаёт PORT сам; локально по умолчанию 8080)
PORT=8080

# Публичный адрес сайта
SITE_ORIGIN=https://bententrade.uz

# Каталог для медиа (на Railway — путь примонтированного Volume, напр. /data)
MEDIA_DIR=./uploads

# Одноразовый токен для назначения первого администратора (/api/auth/bootstrap-admin)
ADMIN_BOOTSTRAP_TOKEN=change-me

# Уведомления в Telegram (необязательно)
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=
